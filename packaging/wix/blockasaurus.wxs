<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Blockasaurus"
           Manufacturer="chrissnell"
           Version="$(var.Version)"
           UpgradeCode="a1e3b5c7-9d2f-4e6a-8b0c-d4f6e8a2c0b4"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Blockasaurus is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="Blockasaurus" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="PathEntry" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Blockasaurus" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="b2f4d6e8-0a1c-3e5b-7d9f-c8e0a2b4d6f8">
        <File Id="blockasaurus.exe" Source="$(var.BinaryPath)" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="PathEntry" Directory="INSTALLFOLDER">
      <Component Id="PathEnv" Guid="c3a5b7d9-1e2f-4c6a-8b0d-e4f6a8c0d2b4">
        <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]"
                     Permanent="no" Part="last" Action="set" System="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>

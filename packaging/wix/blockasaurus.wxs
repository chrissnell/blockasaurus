<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Blockasaurus"
           Manufacturer="chrissnell"
           Version="$(var.Version)"
           UpgradeCode="a1e3b5c7-9d2f-4e6a-8b0c-d4f6e8a2c0b4"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Blockasaurus is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="Blockasaurus" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="ConfigComponents" />
    </Feature>
  </Package>

  <!-- Install directory -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Blockasaurus" />
    </StandardDirectory>
  </Fragment>

  <!-- Binary + Windows service registration -->
  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="b2f4d6e8-0a1c-3e5b-7d9f-c8e0a2b4d6f8">
        <File Id="blockasaurus.exe" Source="$(var.BinaryPath)" KeyPath="yes" />
        <ServiceInstall Id="BlockasaurusService"
                        Name="blockasaurus"
                        DisplayName="Blockasaurus DNS"
                        Description="DNS proxy and ad-blocker for local network"
                        Start="auto"
                        Type="ownProcess"
                        ErrorControl="normal"
                        Arguments="serve --config &quot;[INSTALLFOLDER]config.yml&quot;" />
        <ServiceControl Id="BlockasaurusServiceControl"
                        Name="blockasaurus"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Default config file -->
  <Fragment>
    <ComponentGroup Id="ConfigComponents" Directory="INSTALLFOLDER">
      <Component Id="ConfigFile" Guid="d4e6f8a0-2b1c-4d3e-5f6a-7b8c9d0e1f2a"
                 NeverOverwrite="yes" Permanent="yes">
        <File Id="config.yml" Source="$(var.ConfigPath)" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
